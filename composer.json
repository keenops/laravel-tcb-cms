{
    "name": "keenops/laravel-tcb-cms",
    "description": "Laravel package for integrating with Tanzania Commercial Bank's Cash Management System (CMS) API",
    "keywords": ["laravel", "tcb", "cms", "payment", "tanzania", "bank"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Kimwalu",
            "email": "git@kimwalu.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Keenops\\LaravelTcbCms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Keenops\\LaravelTcbCms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Keenops\\LaravelTcbCms\\TcbCmsServiceProvider"
            ],
            "aliases": {
                "TcbCms": "Keenops\\LaravelTcbCms\\Facades\\TcbCms"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
